  {
    "id": "方煜泽-dialog",
    "name": "记忆碎片",
    "character": "方煜泽",
    "artist": "方煜泽 · R&B Ballad（R&B抒情曲），带",
    "src": "方煜泽-dialog.mp3",
    "avatar": "https://xingyeai-images-cdn.oss-cn-shanghai.aliyuncs.com/talkie-user-img/61198570225823/311476254057536.jpeg",
    "genre": "R&B Ballad（R&B抒情曲），带有轻微的电子合成器音色，营造出一种迷离、内敛而又充满情感张力的氛围。",
    "lyrics": [
      {
        "time": 0,
        "text": "♪ Verse1 ♪"
      },
      {
        "time": 4,
        "text": "冰冷话语 逼近你"
      },
      {
        "time": 8,
        "text": "眼神闪烁 不确定"
      },
      {
        "time": 12,
        "text": "那件衣物 我曾给？"
      },
      {
        "time": 16,
        "text": "你的沉默 刺痛心"
      },
      {
        "time": 20,
        "text": "追问细节 却茫然"
      },
      {
        "time": 24,
        "text": "记忆空白 怎么填"
      },
      {
        "time": 28,
        "text": "你戴着它 却忘了"
      },
      {
        "time": 32,
        "text": "我竟全然 不知情"
      },
      {
        "time": 36,
        "text": "♪ Chorus ♪"
      },
      {
        "time": 40,
        "text": "是谁忘了 谁在演"
      },
      {
        "time": 44,
        "text": "碎片记忆 难分辨"
      },
      {
        "time": 48,
        "text": "你我之间 隔着雾"
      },
      {
        "time": 52,
        "text": "模糊真相 怎么触"
      },
      {
        "time": 56,
        "text": "手腕轻触 却松开"
      },
      {
        "time": 60,
        "text": "眼底惊恐 难掩盖"
      },
      {
        "time": 64,
        "text": "人格分裂 疑虑深"
      },
      {
        "time": 68,
        "text": "我的世界 崩塌沉"
      },
      {
        "time": 72,
        "text": "♪ Verse2 ♪"
      },
      {
        "time": 76,
        "text": "那些话语 像回声"
      },
      {
        "time": 80,
        "text": "你轻声说 我听闻"
      },
      {
        "time": 84,
        "text": "“别弄丢了 随时知”"
      },
      {
        "time": 88,
        "text": "我紧握着 却无知"
      },
      {
        "time": 92,
        "text": "你眼神中 有慌乱"
      },
      {
        "time": 96,
        "text": "我也回望 心胆颤"
